### Settings from original zathurarc ###
set pages-per-row 1
set scroll-page-aware "true"
set scroll-full-overlap 0.01
set scroll-step 100

### zathura-pywal ###
# Allow recolor
set recolor 'true'

# Don't allow original hue when recoloring
set recolor-keephue 'false'

# Don't keep original image colors while recoloring
set recolor-reverse-video 'false'

# Command line completion entries
set completion-fg '#ebdbb2'
set completion-bg '#282828'

# Command line completion group elements
set completion-group-fg '#ebdbb2'
set completion-group-bg '#282828'

# Current command line completion element
set completion-highlight-fg '#282828'
set completion-highlight-bg '#ebdbb2'

# Default foreground/background color
set default-bg rgba(43,43,43,1)

# Input bar
set inputbar-fg '#ebdbb2'
set inputbar-bg '#282828'

# Notification
set notification-fg '#ebdbb2'
set notification-bg '#282828'

# Error notification
set notification-error-fg '#ebdbb2'
set notification-error-bg '#355B88'

# Warning notification
set notification-warning-fg '#ebdbb2'
set notification-warning-bg '#355B88'

# Tab - TODO
# set tabbar-fg
# set tabbar-bg

# Focused tab - TODO
# set tabbar-focus-fg
# set tabbar-focus-bg

# Status bar
set statusbar-fg '#ebdbb2'
set statusbar-bg '#282828'

# Highlighting parts of the document (e.g. show search results)
set highlight-color rgba(204,36,29,0.5)
set highlight-active-color rgba(215,153,33,0.5)

# Represent light/dark colors in recoloring mode
set recolor-lightcolor rgba(43,43,43,1)
set recolor-darkcolor rgba(235,219,178,1)

# 'Loading...' text
set render-loading-fg '#ebdbb2'
set render-loading-bg '#282828'

