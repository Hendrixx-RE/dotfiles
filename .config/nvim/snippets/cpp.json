{
  "Modular Arithmetic": {
    "prefix": "mod",
    "body": [
      "using i64 = long long;",
      "",
      "// Fast exponentiation",
      "template<class T>",
      "constexpr T power(T a, i64 b) {",
      "    T res = 1;",
      "    for (; b; b /= 2, a *= a) {",
      "        if (b % 2) res *= a;",
      "    }",
      "    return res;",
      "}",
      "",
      "// Modular Integer (optimized for 998244353 or 1e9+7)",
      "template<int P>",
      "struct MInt {",
      "    int x;",
      "    static int Mod;",
      "    constexpr static int getMod() { return P > 0 ? P : Mod; }",
      "    constexpr static void setMod(int m) { Mod = m; }",
      "    constexpr MInt(i64 x = 0) : x((x %= getMod()) < 0 ? x + getMod() : x) {}",
      "    constexpr int val() const { return x; }",
      "    constexpr MInt operator-() const { return MInt(getMod() - x); }",
      "    constexpr MInt inv() const { return power(*this, getMod() - 2); }",
      "",
      "    constexpr MInt &operator+=(MInt rhs) { x += rhs.x; if (x >= getMod()) x -= getMod(); return *this; }",
      "    constexpr MInt &operator-=(MInt rhs) { x -= rhs.x; if (x < 0) x += getMod(); return *this; }",
      "    constexpr MInt &operator*=(MInt rhs) { x = 1LL * x * rhs.x % getMod(); return *this; }",
      "    constexpr MInt &operator/=(MInt rhs) { return *this *= rhs.inv(); }",
      "",
      "    friend constexpr MInt operator+(MInt a, MInt b) { return a += b; }",
      "    friend constexpr MInt operator-(MInt a, MInt b) { return a -= b; }",
      "    friend constexpr MInt operator*(MInt a, MInt b) { return a *= b; }",
      "    friend constexpr MInt operator/(MInt a, MInt b) { return a /= b; }",
      "    friend ostream &operator<<(ostream &os, const MInt &a) { return os << a.val(); }",
      "    friend istream &operator>>(istream &is, MInt &a) { i64 v; is >> v; a = MInt(v); return is; }",
      "    friend constexpr bool operator==(MInt a, MInt b) { return a.x == b.x; }",
      "    friend constexpr bool operator!=(MInt a, MInt b) { return a.x != b.x; }",
      "};",
      "template <int P> int MInt<P>::Mod;",
      "template <> int MInt<0>::Mod = 998244353;",
      "",
      "// Set Mod here",
      "constexpr int mod = MOD;",
      "using Z = MInt<mod>;"
    ],
    "description": "Modular Arithmetic Setup"
  },
  "Sieve of Eratosthenes": {
    "prefix": "sieve",
    "body": [
      "bool arr[10]; // O(nloglogn)",
      "void sieve(int n) {",
      "    for(int i=0; i<=n; ++i) {",
      "        arr[i] = 1;",
      "    }",
      "    arr[0] = arr[1] = 0;",
      "    for(int i=2; i<=n; ++i) {",
      "        if (arr[i]) {",
      "            for (int j=i*i; j<=n; j+=i) {",
      "                arr[j] = 0;",
      "            }",
      "        }",
      "    }",
      "}"
    ],
    "description": "Sieve of Eratosthenes"
  },
  "Binary Exponentiation": {
    "prefix": "binexp",
    "body": [
      "int binExp(int a, int b, int m) {",
      "    int c = 1;",
      "    while (b) {",
      "        if (b & 1) c = ((c % m) * (a % m)) % m;",
      "        a = ((a % m) * (a % m)) % m;",
      "        b >>= 1;",
      "    }",
      "    return c;",
      "}"
    ],
    "description": "Binary Exponentiation"
  },
