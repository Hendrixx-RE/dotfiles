  "DFS": {
    "prefix": "dfs",
    "body": [
      "vector<bool> check(N);",
      "void dfs(vector<vector<int>> &v, int node) {",
      "    check[node] = true;",
      "    // visit code",
      "    for (auto it : v[node]) {",
      "        if (!check[it]) {",
      "            dfs(v, it);",
      "        }",
      "    }",
      "}"
    ],
    "description": "Depth First Search"
  },
  "BFS": {
    "prefix": "bfs",
    "body": [
      "vector<bool> check(N);",
      "void bfs(vector<vector<int>> &v, int node) {",
      "    queue<int> q;",
      "    q.push(node);",
      "    while (q.size()) {",
      "        int ver = q.front();",
      "        q.pop();",
      "        if (!check[ver]) {",
      "            check[ver] = true;",
      "            // visit",
      "            for (auto it : v[ver]) {",
      "                if (!check[it.first]) {",
      "                    q.push(it.first);",
      "                }",
      "            }",
      "        }",
      "    }",
      "}"
    ],
    "description": "Breadth First Search"
  },
