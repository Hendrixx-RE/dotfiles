  "Disjoint Set Union (DSU)": {
    "prefix": "dsu",
    "body": [
      "class DSU {",
      "public:",
      "    int nodes;",
      "    vector<int> parent, size;",
      "    DSU(int n) {",
      "        parent.resize(n + 1);",
      "        size.resize(n + 1);",
      "        for (int i = 1; i <= n; ++i) {",
      "            parent[i] = i;",
      "            size[i] = 1;",
      "        }",
      "    }",
      "    int find_parent(int x) {",
      "        if (parent[x] == x) return x;",
      "        return parent[x] = find_parent(parent[x]);",
      "    }",
      "    void union_fun(int a, int b) {",
      "        int par1 = find_parent(a), par2 = find_parent(b);",
      "        if (par1 != par2) {",
      "            if (size[par1] <= size[par2]) {",
      "                parent[par1] = par2;",
      "                size[par2] += size[par1];",
      "            }",
      "            else {",
      "                parent[par2] = par1;",
      "                size[par1] += size[par2];",
      "            }",
      "        }",
      "    }",
      "};"
    ],
    "description": "Simple DSU Implementation"
  }
